# Django Core
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ALLOWED_HOSTS=your-server-ip-or-domain
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=backend.config.settings.production

# Base de datos PostgreSQL
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432

# CORS y CSRF
CORS_ALLOWED_ORIGINS=http://your-server-ip-or-domain
CSRF_TRUSTED_ORIGINS=http://your-server-ip-or-domain:8000

# Seguridad
SECURE_SSL_REDIRECT=False
DJANGO_CSRF_COOKIE_SECURE=False